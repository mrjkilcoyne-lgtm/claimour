---
import Layout from '../layouts/Layout.astro';
---
<Layout title="The sword for anyone the system forgot">

<style>
  /* Z-pattern hero */
  .hero {
    min-height: calc(100vh - 58px);
    display: grid;
    grid-template-rows: 1fr auto;
    position: relative;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 70% 40%, rgba(239,68,68,.07) 0%, transparent 70%),
      radial-gradient(ellipse 40% 60% at 20% 80%, rgba(217,119,6,.04) 0%, transparent 60%);
  }
  /* Diagonal grid lines — subtle */
  .hero-bg::after {
    content: '';
    position: absolute; inset: 0;
    background-image: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 60px,
      rgba(255,255,255,.012) 60px,
      rgba(255,255,255,.012) 61px
    );
  }
  .hero-content {
    position: relative; z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 5rem 1.5rem 3rem;
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
  }
  /* Z-path: top-left eyepath anchor */
  .hero-eyebrow {
    font-size: .65rem;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: .5rem;
  }
  .hero-eyebrow::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 2px;
    background: var(--red);
  }
  .hero-headline {
    font-size: clamp(3rem, 8vw, 6.5rem);
    font-weight: 900;
    line-height: .95;
    letter-spacing: -.05em;
    color: var(--blade);
    margin-bottom: 1.5rem;
    max-width: 800px;
  }
  .hero-headline .accent { color: var(--red); }
  /* Z-path diagonal: sub sweeps right */
  .hero-sub {
    font-size: clamp(.95rem, 2vw, 1.15rem);
    color: var(--muted2);
    line-height: 1.65;
    max-width: 540px;
    margin-bottom: 2.5rem;
    /* Pushes eye diagonally right — classic Z anchor */
    margin-left: clamp(0px, 4vw, 80px);
  }
  .hero-ctas {
    display: flex;
    gap: .75rem;
    flex-wrap: wrap;
    /* Aligns at end of Z-diagonal: bottom-right target */
    margin-left: clamp(0px, 4vw, 80px);
  }

  /* Impact strip — eye continues down left */
  .impact-strip {
    position: relative; z-index: 2;
    border-top: 1px solid var(--border);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    background: var(--surface);
  }
  .impact-cell {
    padding: 1.25rem 1.5rem;
    border-right: 1px solid var(--border);
  }
  .impact-cell:last-child { border-right: none; }
  .impact-num { font-size: 1.6rem; font-weight: 900; letter-spacing: -.04em; line-height: 1; color: var(--red); }
  .impact-label { font-size: .72rem; color: var(--muted2); margin-top: .3rem; line-height: 1.4; }

  @media(max-width: 680px) {
    .impact-strip { grid-template-columns: 1fr 1fr; }
    .impact-cell:nth-child(2) { border-right: none; }
    .hero-headline { font-size: clamp(2.5rem, 10vw, 4rem); }
  }
  @media(max-width: 420px) {
    .impact-strip { grid-template-columns: 1fr; }
    .impact-cell { border-right: none; border-bottom: 1px solid var(--border); }
  }

  /* Section doors — now horizontal scroll on mobile, grid on desktop */
  .doors {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    border-top: 1px solid var(--border);
  }
  @media(max-width: 900px) {
    .doors { grid-template-columns: 1fr 1fr; }
  }
  @media(max-width: 480px) {
    .doors { grid-template-columns: 1fr; }
  }
  .door {
    position: relative;
    padding: 2rem 1.5rem;
    text-decoration: none;
    color: inherit;
    border-right: 1px solid var(--border);
    transition: background .15s;
    display: flex;
    flex-direction: column;
    gap: .65rem;
    min-height: 180px;
  }
  .door:last-child { border-right: none; }
  .door:hover { background: var(--sur2); }
  @media(max-width: 900px) {
    .door { border-bottom: 1px solid var(--border); }
    .door:nth-child(even) { border-right: none; }
  }
  .door-num {
    font-size: .6rem; font-weight: 700; letter-spacing: .14em;
    text-transform: uppercase; color: var(--muted);
  }
  .door-title {
    font-size: 1rem; font-weight: 800; color: var(--blade);
    letter-spacing: -.02em; line-height: 1.2;
  }
  .door-sub {
    font-size: .78rem; color: var(--muted2); line-height: 1.55; flex: 1;
  }
  .door-cta {
    font-size: .68rem; font-weight: 700; letter-spacing: .08em;
    text-transform: uppercase;
  }
  /* Accent bars via border-top */
  .d-rights  { border-top: 3px solid #3b82f6; }
  .d-money   { border-top: 3px solid var(--red); }
  .d-tech    { border-top: 3px solid var(--gold); }
  .d-watch   { border-top: 3px solid var(--green); }
  .d-oracle  { border-top: 3px solid #8b5cf6; }
  .d-rights .door-cta  { color: #3b82f6; }
  .d-money .door-cta   { color: var(--red); }
  .d-tech .door-cta    { color: var(--gold); }
  .d-watch .door-cta   { color: var(--green); }
  .d-oracle .door-cta  { color: #8b5cf6; }
</style>

<div class="hero">
  <div class="hero-bg"></div>

  <div class="hero-content">
    <!-- Z top-left anchor -->
    <div class="hero-eyebrow">Free · UK · No lawyers needed</div>

    <!-- Headline: massive, blade-white, red accent -->
    <h1 class="hero-headline">
      The <span class="accent">sword</span><br/>
      for anyone<br/>
      the system forgot.
    </h1>

    <!-- Sub: shifts right — Z diagonal -->
    <p class="hero-sub">
      UK consumer rights, mental health law, bank accountability,
      and technical power guides. Compiled by someone who knows
      what they get away with every single day.
    </p>

    <!-- CTAs: bottom-right of Z — primary action -->
    <div class="hero-ctas">
      <a href="/rights" class="btn-red" style="font-size:.9rem;padding:.65rem 1.3rem;">Know Your Rights →</a>
      <a href="/oracle" class="btn-ghost" style="font-size:.9rem;padding:.65rem 1.3rem;border-color:rgba(139,92,246,.4);color:#a78bfa;">Ask The Oracle</a>
      <a href="/moneyback" class="btn-ghost" style="font-size:.9rem;padding:.65rem 1.3rem;">Get Money Back</a>
    </div>
  </div>

  <!-- Impact strip — eye anchors bottom-left of Z -->
  <div class="impact-strip">
    <div class="impact-cell">
      <div class="impact-num">£57.4m</div>
      <div class="impact-label">HSBC fined — vulnerable customer failures</div>
    </div>
    <div class="impact-cell">
      <div class="impact-num">46%</div>
      <div class="impact-label">of people in debt have a mental health condition</div>
    </div>
    <div class="impact-cell">
      <div class="impact-num">Free</div>
      <div class="impact-label">FOS is free · bank must comply with decisions</div>
    </div>
    <div class="impact-cell">
      <div class="impact-num">0</div>
      <div class="impact-label">Lawyers needed to start a formal complaint</div>
    </div>
  </div>
</div>

<!-- Section doors -->
<div class="doors">
  <a href="/rights" class="door d-rights">
    <div class="door-num">01 — Rights</div>
    <div class="door-title">Know Your Rights</div>
    <div class="door-sub">LifeBack UK — ten guides. Banking, energy, renting, NHS, council tax. Plain language, template letters.</div>
    <div class="door-cta">Enter →</div>
  </a>
  <a href="/moneyback" class="door d-money">
    <div class="door-num">02 — Claims</div>
    <div class="door-title">Get Your Money Back</div>
    <div class="door-sub">SAR, FOS complaints, chargeback, default challenges. Copy-paste templates.</div>
    <div class="door-cta">Enter →</div>
  </a>
  <a href="/grimoire" class="door d-tech">
    <div class="door-num">03 — Technical</div>
    <div class="door-title">The Grimoire</div>
    <div class="door-sub">Eight volumes. Android power, shadow APIs, financial automation, SIGINT. Free download.</div>
    <div class="door-cta">Enter →</div>
  </a>
  <a href="/watch" class="door d-watch">
    <div class="door-num">04 — Monitor</div>
    <div class="door-title">Bank Hypocrisy Watch</div>
    <div class="door-sub">What banks say about mental health vs what they do. Primary sources only. The receipts, live.</div>
    <div class="door-cta">Enter →</div>
  </a>
  <a href="/oracle" class="door d-oracle">
    <div class="door-num">05 — Opinion</div>
    <div class="door-title">The Oracle</div>
    <div class="door-sub">UK mental health law + financial services. Gives opinions. No sycophancy. Your side, not theirs.</div>
    <div class="door-cta">Consult →</div>
  </a>
</div>

</Layout>

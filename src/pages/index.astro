---
import Layout from '../layouts/Layout.astro';
---
<Layout title="The sword for anyone the system forgot">

<style>
  .doors {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    min-height: calc(100vh - 58px);
  }
  @media(max-width:768px) {
    .doors { grid-template-columns: 1fr 1fr; min-height: auto; }
    .door { min-height: 44vw; }
  }
  @media(max-width:480px) {
    .doors { grid-template-columns: 1fr; }
    .door { min-height: 56vw; }
  }
  .door {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 2rem;
    text-decoration: none;
    color: inherit;
    border-right: 1px solid var(--border);
    overflow: hidden;
    transition: background 0.2s;
    cursor: pointer;
    min-height: 100%;
  }
  .door:last-child { border-right: none; }
  .door::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(7,7,11,0.95) 30%, transparent 100%);
    z-index: 1;
    transition: opacity 0.2s;
  }
  .door:hover::before { opacity: 0.7; }
  .door:hover { background: var(--surface); }
  .door-number {
    position: absolute;
    top: 1.5rem; left: 2rem;
    font-size: .65rem; font-weight: 700;
    letter-spacing: .14em; text-transform: uppercase;
    color: var(--muted); z-index: 2;
    transition: color .2s;
  }
  .door:hover .door-number { color: var(--muted2); }
  .door-icon {
    font-size: 2.8rem; margin-bottom: 1rem;
    z-index: 2; line-height: 1;
    transition: transform .2s;
  }
  .door:hover .door-icon { transform: translateY(-4px); }
  .door-title {
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1.05;
    color: var(--blade);
    z-index: 2;
    margin-bottom: .5rem;
  }
  .door-sub {
    font-size: .8rem;
    color: var(--muted2);
    line-height: 1.5;
    z-index: 2;
    max-width: 220px;
    opacity: 0;
    transform: translateY(8px);
    transition: all .2s;
  }
  .door:hover .door-sub { opacity: 1; transform: translateY(0); }
  .door-arrow {
    display: inline-flex; align-items: center; gap: .3rem;
    margin-top: .75rem;
    font-size: .72rem; font-weight: 700; letter-spacing: .08em;
    text-transform: uppercase;
    z-index: 2;
    transition: gap .15s;
    opacity: 0;
    transition: all .2s;
  }
  .door:hover .door-arrow { opacity: 1; }

  /* Door accent bars */
  .door-rights { border-top: 3px solid #3b82f6; }
  .door-rights .door-arrow { color: #3b82f6; }
  .door-money { border-top: 3px solid var(--red); }
  .door-money .door-arrow { color: var(--red); }
  .door-grimoire { border-top: 3px solid var(--gold); }
  .door-grimoire .door-arrow { color: var(--gold); }
  .door-watch { border-top: 3px solid var(--green); }
  .door-watch .door-arrow { color: var(--green); }

  /* Hero strip above doors */
  .hero-strip {
    border-bottom: 1px solid var(--border);
    padding: 1.25rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: .75rem;
  }
  .hero-tagline {
    font-size: clamp(.8rem, 2vw, .95rem);
    color: var(--muted2);
    font-weight: 400;
  }
  .hero-tagline strong { color: var(--blade); font-weight: 700; }
  .hero-actions { display: flex; gap: .5rem; align-items: center; }
</style>

<div class="z1">
  <!-- Tagline strip -->
  <div class="hero-strip">
    <div class="hero-tagline">
      <strong>Claimour</strong> — free UK consumer rights, legal power & technical guides.
      The sword for anyone the system forgot.
    </div>
    <div class="hero-actions">
      <a href="/grimoire" class="btn-ghost" style="font-size:.78rem;padding:.4rem .85rem;">The Grimoire ↗</a>
      <a href="/donate" class="btn-red" style="font-size:.78rem;padding:.4rem .85rem;">Support ♥</a>
    </div>
  </div>

  <!-- Four Doors -->
  <div class="doors">

    <a href="/rights" class="door door-rights">
      <div class="door-number">01 — Rights</div>
      <div class="door-icon">⚖️</div>
      <div class="door-title">Know Your Rights</div>
      <div class="door-sub">LifeBack UK — ten plainly-written guides. Banking, energy, renting, NHS, council tax. What the system owes you.</div>
      <div class="door-arrow">Enter →</div>
    </a>

    <a href="/moneyback" class="door door-money">
      <div class="door-number">02 — Claims</div>
      <div class="door-icon">💷</div>
      <div class="door-title">Get Your Money Back</div>
      <div class="door-sub">SAR templates. FOS complaints. Bank misconduct. No-win no-fee referrals. Step-by-step.</div>
      <div class="door-arrow">Enter →</div>
    </a>

    <a href="/grimoire" class="door door-grimoire">
      <div class="door-number">03 — Technical</div>
      <div class="door-icon">📖</div>
      <div class="door-title">The Grimoire</div>
      <div class="door-sub">Eight volumes on Android power, shadow APIs, financial automation, SIGINT, and the human layer. Free to download.</div>
      <div class="door-arrow">Enter →</div>
    </a>

    <a href="/watch" class="door door-watch">
      <div class="door-number">04 — Monitor</div>
      <div class="door-icon">👁</div>
      <div class="door-title">Bank Hypocrisy Watch</div>
      <div class="door-sub">Daily scan. What banks say about mental health vs what they actually do. The receipts, live.</div>
      <div class="door-arrow">Enter →</div>
    </a>

  </div>
</div>

</Layout>
